# SchoolLedger Frontend — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# Vite exposes only variables prefixed with VITE_ to the browser bundle.

# Backend API base URL (no trailing slash)
# Development (default when unset):  http://localhost:8080/api
# Production example:                https://api.yourschool.com/api
VITE_API_BASE_URL=http://localhost:8080/api

# Platform control panel API base URL (optional override, no trailing slash)
# When unset, it is derived automatically from VITE_API_BASE_URL + '/platform'.
# Production example:                https://api.yourschool.com/api/platform
# VITE_PLATFORM_API_URL=http://localhost:8080/api/platform
