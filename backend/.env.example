# ─── Application ────────────────────────────────────────────────────────────
CI_ENVIRONMENT = development
app.baseURL = 'http://localhost:8080/'
# System timezone is Africa/Harare (GMT+2). Configured in app/Config/App.php.

# Public-facing frontend application URL used to build links in outgoing emails.
SITE_URL = 'http://localhost:8081'

# ─── Database ────────────────────────────────────────────────────────────────
database.default.hostname = localhost
database.default.database = schoolledger
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY = your-secret-key-here

# ─── Paynow Integration ──────────────────────────────────────────────────────
PAYNOW_INTEGRATION_ID = your_paynow_integration_id
PAYNOW_INTEGRATION_KEY = your_paynow_integration_key
PAYNOW_RESULT_URL = http://localhost:8080/api/subscription/webhook
PAYNOW_RETURN_URL = http://localhost:5173/billing?payment=complete

# ─── Subscription ────────────────────────────────────────────────────────────
SUBSCRIPTION_CURRENCY = USD

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Maximum requests per minute for unauthenticated (IP-keyed) clients
RATE_LIMITER_UNAUTHENTICATED_LIMIT = 60
# Maximum requests per minute for authenticated (user-keyed) clients
RATE_LIMITER_AUTHENTICATED_LIMIT = 120

# ─── Production ───────────────────────────────────────────────────────────────
# For production deployments, update these values:
#   CI_ENVIRONMENT = production
#   database.default.hostname = <prod-db-host>
#   database.default.database = <prod-db-name>
#   database.default.username = <prod-db-user>
#   database.default.password = <prod-db-password>
#   database.default.DBDebug  = false
#   JWT_SECRET_KEY = <strong-random-secret>
